   "source": [
    "def factors(x):\n",
    "    f_list = []\n",
    "\n",
    "    for i in range(1, x + 1):\n",
    "        if x % i == 0:\n",
    "            f_list.append(i)\n",
    "\n",
    "    return f_list"
   ],
   "outputs": []
  },
